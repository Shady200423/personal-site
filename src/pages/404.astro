---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Page not found" description="This page does not exist.">
  <section class="section">
    <div class="container-wide">
      <div class="mx-auto max-w-xl text-center">
        <h1 class="text-4xl font-display">404</h1>
        <p class="mt-4 text-lg text-ink-700 dark:text-ink-200">
          This page could not be found.
        </p>
        <a class="solid-button mt-6" href="/en/">Back to home</a>
      </div>
    </div>
  </section>
</BaseLayout>
