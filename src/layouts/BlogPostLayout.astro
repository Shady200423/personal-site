---
import BaseLayout from "./BaseLayout.astro";
import TagList from "../components/TagList.astro";
import Giscus from "../components/Giscus.astro";

const { entry, lang } = Astro.props;
const { title, description, date, tags } = entry.data;
const formatted = new Intl.DateTimeFormat(lang, {
  year: "numeric",
  month: "long",
  day: "numeric"
}).format(date);
---

<BaseLayout title={title} description={description} lang={lang} ogType="article">
  <article class="section">
    <div class="container-wide">
      <div class="mx-auto max-w-3xl">
        <p class="text-xs uppercase tracking-wide text-ink-600 dark:text-ink-300">{formatted}</p>
        <h1 class="mt-4 text-4xl font-display md:text-5xl">{title}</h1>
        <p class="mt-4 text-lg text-ink-700 dark:text-ink-200">{description}</p>
        <div class="mt-6">
          <TagList tags={tags} lang={lang} />
        </div>
        <div class="prose prose-lg mt-10 max-w-none prose-headings:font-display prose-p:text-ink-700 dark:prose-invert dark:prose-p:text-ink-200">
          <slot />
        </div>
        <div class="mt-16">
          <Giscus lang={lang} />
        </div>
      </div>
    </div>
  </article>
</BaseLayout>
