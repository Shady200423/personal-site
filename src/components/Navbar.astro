---
import { navLinks, site } from "../data/site";
import ThemeToggle from "./ThemeToggle.astro";
import LanguageSwitcher from "./LanguageSwitcher.astro";

const { lang, path } = Astro.props;
const links = navLinks(lang);
---

<header class="border-b border-ink-200/60 bg-ink-50/80 backdrop-blur dark:border-ink-700/60 dark:bg-ink-900/80">
  <div class="container-wide flex items-center justify-between py-5">
    <a class="text-lg font-display font-semibold tracking-tight" href={`/${lang}/`}>
      {site.name}
    </a>
    <nav class="hidden gap-6 text-sm uppercase tracking-wide lg:flex">
      {links.map((link) => (
        <a class="hover:underline" href={link.href}>{link.label}</a>
      ))}
    </nav>
    <div class="flex items-center gap-3">
      <LanguageSwitcher lang={lang} path={path} />
      <ThemeToggle />
    </div>
  </div>
  <nav class="border-t border-ink-200/60 px-6 py-3 text-xs uppercase tracking-wide lg:hidden dark:border-ink-700/60">
    <div class="mx-auto flex max-w-6xl flex-wrap gap-4">
      {links.map((link) => (
        <a class="hover:underline" href={link.href}>{link.label}</a>
      ))}
    </div>
  </nav>
</header>
