---
const giscusLang = "it";
---

<div class="glass">
  <h3 class="text-lg font-display">Discussion</h3>
  <p class="mt-2 text-sm text-ink-700 dark:text-ink-200">
    Comments are powered by Giscus. Replace the repo and category IDs to activate comments.
  </p>
  <div class="mt-6">
    <script
      src="https://giscus.app/client.js"
      data-repo="Shady200423/personal-site"
      data-repo-id="R_kgDORnN6lA"
      data-category="General"
      data-category-id="DIC_kwDORnN6lM4C4Ztt"
      data-mapping="pathname"
      data-strict="0"
      data-reactions-enabled="1"
      data-emit-metadata="0"
      data-input-position="top"
      data-theme="preferred_color_scheme"
      data-lang={giscusLang}
      crossorigin="anonymous"
      async
    ></script>
  </div>
</div>
