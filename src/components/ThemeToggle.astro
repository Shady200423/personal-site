<button
  class="inline-flex h-9 w-9 items-center justify-center rounded-full border border-ink-300/70 text-ink-800 transition hover:border-ink-800 dark:border-ink-600/70 dark:text-ink-100 dark:hover:border-ink-200"
  type="button"
  aria-label="Toggle dark mode"
  data-theme-toggle
>
  <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" aria-hidden="true">
    <path
      d="M12 3.5a1 1 0 0 1 1 1v1.2a1 1 0 1 1-2 0V4.5a1 1 0 0 1 1-1Zm6.5 7.5a1 1 0 0 1 1 1v1.1a1 1 0 1 1-2 0V12a1 1 0 0 1 1-1Zm-12 0a1 1 0 0 1 1 1v1.1a1 1 0 1 1-2 0V12a1 1 0 0 1 1-1ZM6 6a1 1 0 0 1 1.4 0l.8.8a1 1 0 0 1-1.4 1.4l-.8-.8A1 1 0 0 1 6 6Zm10.8 10.8a1 1 0 0 1 1.4 0l.8.8a1 1 0 1 1-1.4 1.4l-.8-.8a1 1 0 0 1 0-1.4ZM17 6a1 1 0 0 1 1.4 0 1 1 0 0 1 0 1.4l-.8.8a1 1 0 0 1-1.4-1.4l.8-.8ZM6.8 16.8a1 1 0 0 1 1.4 0 1 1 0 0 1 0 1.4l-.8.8a1 1 0 0 1-1.4-1.4l.8-.8ZM12 7a5 5 0 1 1 0 10 5 5 0 0 1 0-10Z"
      fill="currentColor"
    />
  </svg>
</button>

<script>
  const button = document.querySelector("[data-theme-toggle]");
  const root = document.documentElement;

  const applyTheme = (theme) => {
    const isDark = theme === "dark";
    root.classList.toggle("dark", isDark);
  };

  const stored = localStorage.getItem("theme");
  if (stored) applyTheme(stored);

  button?.addEventListener("click", () => {
    const next = root.classList.contains("dark") ? "light" : "dark";
    localStorage.setItem("theme", next);
    applyTheme(next);
  });
</script>
